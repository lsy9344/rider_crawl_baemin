# rider_server backend-api 환경 변수 — Story 5.1~5.8 (정본: src/rider_server/settings.py Settings.from_env).
#
# 평문 secret 금지: token/password 등은 이 파일에 두지 않고 *_ref(불투명 핸들) 또는
# 배포 secret 주입 메커니즘으로만 다룬다(평문 커밋 금지). 텔레그램 webhook/봇 ref 는
# deploy/env/telegram-webhook.env 참조.
APP_ENV=production
APP_VERSION=0.1.0

# 빌드 파이프라인이 주입(미설정 시 /version 에 노출하지 않음):
# BUILD_SHA=
# BUILD_TIME=

# 기동 포트(기본 8000):
# PORT=8000

# ── DB (Story 5.2) ──
# async SQLAlchemy 연결 문자열(예: postgresql+asyncpg://user:pass@host:5432/db).
# 비밀번호 포함 — 이 파일에 평문 커밋 금지, 배포 시 secret 주입으로 채운다(미설정 시 None).
# DATABASE_URL=postgresql+asyncpg://USER:***@db:5432/rider

# ── Admin 접근 보안·복구 (Story 5.8) ──
# 복구/신규 환경 실전송 게이트. 기본 OFF(fail-closed, NFR-9·25) — 운영자가 명시 활성화해야 발송.
# truthy(1/true/yes/on)만 활성화.
# RIDER_SENDING_ENABLED=false
# Admin 접근 허용 source IP/CIDR(콤마 구분). 미설정/빈 값 = 추가 IP 제한 없음(opt-in).
# RIDER_ADMIN_IP_ALLOWLIST=10.0.0.0/8,203.0.113.10
# privileged 액션의 MFA 강제 토글. 기본 True(게이트레일 #4) — false 로만 해제.
# RIDER_ADMIN_MFA_REQUIRED=true
