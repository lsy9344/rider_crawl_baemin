# rider_server Telegram webhook 환경 변수 — Story 5.5 (ADD-12).
#
# 평문 secret 금지: webhook secret·봇 토큰은 이 파일에 **평문으로 두지 않는다**. 기본 배포는
# `env:NAME` ref만 해석하므로, 실제 secret 값은 host/CI secret으로 NAME 환경변수에 주입한다.
# Vault/KMS ref는 `app.state.resolve_telegram_secret`/`resolve_telegram_token` 주입 seam 교체 후 쓴다.
#
# 아래는 **플레이스홀더(예시)** 다 — 배포 시 실제 ref 핸들로 교체한다(평문 커밋 금지).

# Telegram 이 webhook 호출 시 X-Telegram-Bot-Api-Secret-Token 헤더로 보내는 secret 의 참조 핸들.
# (setWebhook(secret_token=...) 로 등록한 값과 동일한 secret 을 가리키는 ref)
# TELEGRAM_WEBHOOK_SECRET_REF=env:RIDER_TELEGRAM_WEBHOOK_SECRET

# 중앙 send-only 테스트 메시지 발송에 쓰는 봇 토큰의 참조 핸들.
# TELEGRAM_BOT_TOKEN_REF=env:RIDER_TELEGRAM_BOT_TOKEN

# 운영 단계에서 Telegram 에 등록할 공개 webhook URL(예: https://api.example.com/v1/telegram/webhook).
# 비밀 아님(공개 엔드포인트) — setWebhook 등록 스크립트/운영 절차가 참조한다.
# TELEGRAM_WEBHOOK_PUBLIC_URL=https://api.example.com/v1/telegram/webhook
