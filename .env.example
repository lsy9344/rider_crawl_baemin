# PERFORMANCE_PLATFORM=baemin  # baemin 또는 coupang. 기본 baemin
BAEMIN_DELIVERY_HISTORY_URL=https://deliverycenter.baemin.com/delivery/history?page=0&size=20&orderName=name&orderBy=asc&name=&userId=&phoneNumber=&riderStatus=
# BAEMIN_CENTER_NAME은 두 플랫폼 모두에서 쓰입니다.
#  - 배민: 센터 검증용 센터명(아래 기본값).
#  - 쿠팡: "기대 센터/상점명"으로 재사용되며 필수입니다(자세한 내용은 아래 쿠팡 주석 참고).
# BAEMIN_CENTER_ID는 배민 전용이며 쿠팡에서는 사용하지 않습니다.
BAEMIN_CENTER_NAME=표준서울마포B이츠앤홀딩스3
BAEMIN_CENTER_ID=DP2605181318
# 쿠팡이츠(PERFORMANCE_PLATFORM=coupang)로 실행할 때만 사용합니다.
# 쿠팡은 로그인 직후 열리는 peak-dashboard 한 페이지만 읽습니다(주 URL 기본값).
# COUPANG_EATS_URL=https://partner.coupangeats.com/page/peak-dashboard
# PEAK_DASHBOARD_URL은 더 이상 사용하지 않습니다(설정해도 무시됨).
# PERFORMANCE_URL=  # 플랫폼과 무관하게 주 URL을 강제로 덮어쓰고 싶을 때 사용
# 쿠팡 실행 시 BAEMIN_CENTER_NAME을 "기대 센터/상점명"으로 재사용합니다(배민
# 센터 ID는 쓰지 않음). 포트/프로필 오연결로 다른 쿠팡 계정 실적을 보내는 일을
# 막기 위한 값이라, 쿠팡에서는 실제 쿠팡 센터/상점명을 반드시 채워야 합니다.
# 배민 기본값(표준서울마포...)이 그대로면 실행 시 설정 오류가 납니다.
# (쿠팡 실행 예) BAEMIN_CENTER_NAME=쿠팡강남센터
BROWSER_MODE=cdp
CDP_URL=http://127.0.0.1:9222
BROWSER_USER_DATA_DIR=C:\rider_crawl\browser-profile
HEADLESS=false
KAKAO_CHAT_NAME=실적봇_의정부남부
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_MESSAGE_THREAD_ID=
MESSENGER_NAME=telegram
CRAWL_NAME=크롤링1
STATE_SUBDIR=crawling1
LOG_DIR=C:\rider_crawl\logs
SEND_ENABLED=false
SEND_ONLY_ON_CHANGE=false
TIMEZONE=Asia/Seoul
RUN_LOCK_TIMEOUT_SECONDS=900
PAGE_TIMEOUT_SECONDS=60000

# === 쿠팡이츠 이메일 2차 인증 자동 복구 ===
# 자동복구 설정(쿠팡 아이디/비밀번호, 인증 이메일 주소/앱 비밀번호)은 .env가 아니라 UI의
# 각 크롤링 탭에서 직접 입력합니다(평문 저장, 텔레그램 토큰 등 기존 비밀값과 동일 방식).
# 인증 이메일은 Gmail/Naver를 IMAP(주소+앱 비밀번호)로 통일하며, 공급자는 주소 도메인으로
# 자동 결정합니다. Gmail OAuth/토큰 파일은 더 이상 사용하지 않습니다.
# 주의: CLI(--once) 실행은 탭을 특정할 수 없어 이메일 자동복구를 지원하지 않습니다
# (자동복구 기본 off 유지). UI에서 탭별로 켜서 사용하세요.
