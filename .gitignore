.venv/
.pytest_cache/
.codegraph/
__pycache__/
*.py[cod]
runtime/
logs/
# 탭별 로그 디렉터리(크롤링3=logs3 등 log_dir이 logs가 아닌 경우)도 무시한다.
logs*/
.env
secrets/google/*.json
secrets/google/*.pickle
secrets/google/token*
secrets/google/credentials*
# PyInstaller rebuild artifacts (the shipped exe in dist/ is tracked via LFS).
build/
# 기준선/설정 백업 zip은 실제 secret(.env, runtime/state/ui_settings.json 등)을 포함하므로 절대 커밋하지 않는다.
backups/
# 작업지시서/요구사항 PDF 등 외부 문서는 코드 저장소에 두지 않는다.
*.pdf
.claude/.story-automator-active
.claude/
.codex/
.agents/

# 로컬 디버그/런타임 산출물 (커밋 금지)
deploy/docker-compose.dev-admin-view.yml
agent-run.lock
.playwright-cli/
